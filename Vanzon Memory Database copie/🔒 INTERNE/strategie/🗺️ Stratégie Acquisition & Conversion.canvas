	"nodes":[
		{"id":"g_tunnel","type":"group","x":1850,"y":-280,"width":700,"height":2300,"color":"2","label":"📱 TUNNEL VBA (Meta Ads → Achat)"},
		{"id":"g_seo","type":"group","x":-100,"y":320,"width":1800,"height":580,"color":"3","label":"📝 SEO — 3 catégories d'articles blog"},
